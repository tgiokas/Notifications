# Notifications DB Configuration
NOTIFY_DB_POSTGRES_USER=notifyuser
NOTIFY_DB_POSTGRES_PASSWORD=notifypass
NOTIFY_DB_POSTGRES_DB=notifydb
NOTIFY_DB_CONNECTION=Host=notify-db;Database=notifydb;Username=notifyuser;Password=notifypass;Include Error Detail=true

EMAIL_PROVIDER=smtp

# SendGrid Configuration
SENDGRID_API_KEY=sendgrid-api-key
SENDGRID_FROM_EMAIL=sendgrid-verified-email
SENDGRID_FROM_NAME=Archium

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=giokaspan@gmail.com
SMTP_PASSWORD=nhcvhgvsomperylp
SMTP_FROM=no-reply@example.com

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka1:9092

# Kafka Consumer - Notifications Configuration
NOTIFY_KAFKA_RECONNECT_BACKOFF_MS=50
NOTIFY_KAFKA_RECONNECT_BACKOFF_MAX_MS=5000
NOTIFY_KAFKA_TOPICS=notifications.email.auth,notifications.email.backend
NOTIFY_KAFKA_GROUP_ID=email-consumers
NOTIFY_KAFKA_AUTO_OFFSET_RESET=Earliest
NOTIFY_KAFKA_ENABLE_AUTO_COMMIT=false
NOTIFY_KAFKA_AUTO_COMMIT_INTERVAL_MS=5000
NOTIFY_KAFKA_SESSION_TIMEOUT_MS=30000
NOTIFY_KAFKA_MAX_POLL_INTERVAL_MS=300000
NOTIFY_KAFKA_API_VERSION_REQUEST_TIMEOUT_MS=10000